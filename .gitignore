# --- Segredos / ambiente ---
# Nunca commitar chaves; os .env.example ficam versionados.
.env
.env.*
!.env.example
venv/
.venv/
env/

# --- Python ---
__pycache__/
*.py[cod]
*.egg-info/
build/
dist/

# --- Caches de teste / lint / tipos ---
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
htmlcov/

# --- Sistema operacional / editor ---
.DS_Store
*.swp

# --- Projeto (monorepo INT/UnB chatbot) ---
# Dados brutos e processados NÃO vão pro repo (gerados pelo pipeline).
# backend/chroma_db/ é a EXCEÇÃO: o vector store é comitado (o re-scraping o
# atualiza e recommita), então não entra aqui.
backend/data/raw/*
!backend/data/raw/.gitkeep
backend/data/processed/*
!backend/data/processed/.gitkeep

# --- Frontend ---
node_modules/
frontend/dist/
