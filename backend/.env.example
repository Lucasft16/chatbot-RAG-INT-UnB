# Copie para .env e preencha. NUNCA comite o .env (já está no .gitignore).

# --- Provedor de LLM / Embeddings ---
# Chave do Google AI Studio: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Modelos (sobrescreva se as quotas/nomes mudarem)
GEMINI_GENERATION_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# --- Vector store ---
CHROMA_DB_DIR=chroma_db
CHROMA_COLLECTION=int_unb

# --- Retrieval ---
RETRIEVAL_TOP_K=5

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000
# Origens permitidas para CORS (frontend), separadas por vírgula
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
